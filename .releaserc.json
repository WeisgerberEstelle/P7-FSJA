{
  "branches": ["main"],
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    ["@semantic-release/changelog", {
      "changelogFile": "CHANGELOG.md"
    }],
    ["@semantic-release/exec", {
      "publishCmd": "echo \"new_release_version=${nextRelease.version}\" >> $GITHUB_OUTPUT && echo \"new_release_published=true\" >> $GITHUB_OUTPUT"
    }],
    ["@semantic-release/github", {
      "assets": [
        { "path": "microcrm-back.jar", "label": "Backend - Spring Boot JAR (Java 17)" },
        { "path": "microcrm-front.tar.gz", "label": "Frontend - Angular (fichiers statiques)" }
      ]
    }],
    ["@semantic-release/git", {
      "assets": ["CHANGELOG.md"],
      "message": "chore(release): ${nextRelease.version}\n\n${nextRelease.notes}"
    }]
  ]
}
